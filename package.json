{
  "name": "apiboost",
  "type": "module",
  "version": "1.0.4",
  "private": false,
  "description": "一个增强api文档的工具",
  "keywords": [
    "apiboost",
    "zpeak",
    "api",
    "boost",
    "openapi",
    "generate",
    "swagger"
  ],
  "author": {
    "name": "peak",
    "email": "zpeak.dev@outlook.com",
    "url": "https://zhanggaofeng.cn"
  },
  "homepage": "https://github.com/zpeakdev/apiboost",
  "repository": {
    "type": "git",
    "url": "https://github.com/zpeakdev/apiboost.git"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    }
  },
  "bin": {
    "apiboost": "./dist/bin/generate.mjs"
  },
  "scripts": {
    "build": "tsc",
    "build:un": "unbuild",
    "test": "tsx bin/generate.ts",
    "generate": "node dist/bin/generate.js",
    "g": "pnpm build &&  node dist/bin/generate.js",
    "release": "npx bumpp --excute=\"pnpm i && pnpm build\"",
    "pb": "pnpm publish"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.9.1",
    "typescript": "^5.6.3",
    "unbuild": "^3.6.1"
  },
  "dependencies": {
    "@zpeak/openapi-adapter": "^1.0.12",
    "fs-extra": "^11.3.3",
    "tsx": "^4.21.0"
  }
}
